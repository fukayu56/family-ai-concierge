# Client (Expo)
# Copy to `.env` in the project root (same folder as package.json).
# Restart `npx expo start` after changing this file.

# Physical device on the same Wi-Fi as the PC running the API:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:3001

# Local Expo Web / same-machine (used when unset in development):
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# Production on Vercel (same origin): leave EXPO_PUBLIC_API_BASE_URL unset.
# The client will call /api/* and /health on the same host.
# Never set EXPO_PUBLIC_OPENAI_API_KEY (or any OpenAI key) on the client.

# Server (local): put OPENAI_API_KEY in server/.env
# OPENAI_API_KEY=sk-...
# ALLOWED_ORIGINS=http://localhost:8081
