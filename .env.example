# Client (Expo)
# Copy to `.env` in the project root (same folder as package.json).
# Restart `npx expo start` after changing this file.

# Physical device on the same Wi-Fi as the PC running the API:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:3001

# Expo Web / same-machine default (used when unset):
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3001
